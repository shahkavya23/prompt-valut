{
  "manifest_version": 3,
  "name": "Prompttora",
  "version": "1.0.0",
  "description": "Save, organize, refine, and reuse your best prompts across coding platforms and the web.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["activeTab", "clipboardWrite", "contextMenus", "storage", "scripting"],
  "host_permissions": ["<all_urls>", "https://egxezgbulobcofnonysk.supabase.co/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Prompttora",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "options_page": "src/options.html",
  "commands": {
    "start-snap": {
      "suggested_key": {
        "default": "Alt+Shift+P"
      },
      "description": "Start Prompttora snap tool"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/shared.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/icon-48.png", "assets/icon-128.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
